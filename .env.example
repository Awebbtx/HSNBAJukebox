# -----------------------------------------------------------------------------
# ProxmoxJukebox environment template
# Copy to .env and update values for your deployment.
# -----------------------------------------------------------------------------

# Server
PORT=3000
BASE_URL=http://localhost:3000

# Spotify OAuth + playback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/callback
SPOTIFY_DEVICE_ID=

# Mopidy endpoint (reachable from this app host/container)
MOPIDY_URL=http://127.0.0.1:6680/mopidy/rpc

# Bootstrap admin account fallback password (used only when no admin exists)
ADMIN_BOOTSTRAP_PASSWORD=

# Request/session limits
MAX_PENDING_PER_USER=3
EMPLOYEE_SESSION_TTL_MINUTES=480
REQUESTS_RATE_WINDOW_MS=60000
REQUESTS_RATE_MAX=40

# Content controls
EXPLICIT_FILTER_ENABLED=false

# ASM/Shelter Manager connection
ASM_SERVICE_URL=
ASM_ACCOUNT=
ASM_API_KEY=
ASM_USERNAME=
ASM_PASSWORD=
ASM_ADOPTABLE_METHOD=json_adoptable_animals
ASM_ADOPTABLE_CACHE_SECONDS=600

# Adoptable slideshow runtime defaults
SLIDESHOW_INTERVAL_SECONDS=12
SLIDESHOW_DEFAULT_LIMIT=20
SLIDESHOW_AUDIO_ENABLED=true
SLIDESHOW_AUDIO_SOURCE=/live.mp3
SLIDESHOW_AUDIO_VOLUME=70
SLIDESHOW_AUDIO_AUTOPLAY=false
SLIDESHOW_EXCLUDE_FERAL=true
SLIDESHOW_READY_TODAY_ONLY=true
SLIDESHOW_CUSTOM_FILTERS_ENABLED=false
SLIDESHOW_CUSTOM_FILTERS=

# Legacy migration support (optional)
# These are only used as fallback for older deployments.
SLIDESHOW_DISPLAY_FIELD_MAP=
SLIDESHOW_DISPLAY_FIELDS=
